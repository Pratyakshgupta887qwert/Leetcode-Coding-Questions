class Solution {
    public int maxSubarraySum(int[] arr, int k) {
        // Code here

        int n = arr.length;

        int windowSum = 0;
        for (int i = 0; i < k; i++) {
            windowSum += arr[i];
        }

        int max = windowSum;

        for (int i = k; i < n; i++) {
            windowSum = windowSum + arr[i] - arr[i - k];
            max = Math.max(max, windowSum);
        }

        return max;
    }
}
